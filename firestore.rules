rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // A user can read a document if their UID matches the document's userId.
    // A user can create a document if the new document's userId matches their UID.
    // This single rule covers get, list, create, update, delete operations correctly
    // by ensuring all access is gated by the userId field.
    match /documents/{documentId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;

      // Also allow a user to create a document. The resource is the *new* document.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      match /messages/{messageId} {
        // A user can read/write messages if they own the parent document.
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/$(documentId)).data.userId == request.auth.uid;
      }
    }
  }
}