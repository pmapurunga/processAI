
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // This is the final, secure rule for the 'uploads' directory.
    // It is the trigger path for our background Cloud Function.
    match /uploads/{userId}/{documentId}/{allPaths=**} {
      // Allow write access ONLY to the authenticated user who owns this directory path.
      // This rule is now active and enforces security.
      allow write: if request.auth != null && request.auth.uid == userId
                    && request.resource.size < 20 * 1024 * 1024;

      // Allow read access only to the user who owns the files.
      allow read: if request.auth != null && request.auth.uid == userId;
    }
  }
}
