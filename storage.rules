
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // This rule allows authenticated users to upload files to a directory
    // specific to their user ID and the document ID.
    match /pendingAnalysis/{userId}/{documentId}/{allPaths=**} {
      // Allow write access only to the authenticated user who owns this path.
      // Also, limit the file size to 20MB.
      allow write: if request.auth != null && request.auth.uid == userId
                    && request.resource.size < 20 * 1024 * 1024;

      // Allow read access only to the user who owns the files.
      allow read: if request.auth != null && request.auth.uid == userId;
    }
  }
}
