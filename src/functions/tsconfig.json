{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2021",
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": "../",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "compileOnSave": true,
  "include": [
    "./**/*.ts",
    "../ai/**/*.ts"
  ]
}
