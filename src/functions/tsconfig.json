{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2021",
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "compileOnSave": true,
  "include": [
    "index.ts",
    "document-ai.ts",
    "genkit.config.ts",
    "ai-flows/query-document.ts",
    "ai-flows/summarize-document.ts",
    "ai-flows/tune-ai-persona.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
